{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "edit|write|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-.}\"/hooks/run-hook.sh protect-files.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "edit|write|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-.}\"/hooks/run-hook.sh post-edit-lint.py"
          }
        ]
      }
    ]
  }
}
