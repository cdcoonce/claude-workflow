__pycache__/
*.pyc
.DS_Store
*.egg-info/
.pytest_cache/
.ruff_cache/

# User-local Claude settings
.claude/settings.local.json

# macOS conflict copies (created when checkout hits dirty files)
* 2.*
* 3.*

# Generated preset bundles (populated by the pre-build step before uv build).
# Keep the directory tracked via .gitkeep so fresh checkouts have the dir the
# wheel force-include expects; ignore only its generated contents.
scripts/installer/presets/*
!scripts/installer/presets/.gitkeep

# Build artifacts
dist/

# afk runtime state (machine-local). config.toml is the tracked repo-level afk
# policy; transcripts/, conductor/, and worktrees/ are per-run local state.
# Mirrors afk-agent-system's root .gitignore convention.
.afk/worktrees/
.afk/transcripts/
.afk/conductor/
